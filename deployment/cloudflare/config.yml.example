# Copia este fichero a /etc/collados-party/cloudflared/config.yml en el server
# y sustituye <tunnel-id> por el id real del túnel "collados".
# Las credenciales JSON del túnel van en el mismo directorio.
tunnel: <tunnel-id>
credentials-file: /etc/cloudflared/<tunnel-id>.json
protocol: quic

ingress:
  - hostname: collados.alexdepablos.es
    service: http://web:80
  - service: http_status:404
